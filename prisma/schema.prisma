// ===================================================================
// LeanWear — Modelo de datos (PostgreSQL + Prisma)
//
// Convenciones de dinero:
//   - Se COMPRA en USD  -> los campos de costo terminan en "Usd"
//   - Se VENDE  en UYU  -> los campos de venta terminan en "Uyu"
//   - El tipo de cambio (USD->UYU) es editable: se guarda por pedido
//     (histórico) y como valor por defecto en StoreSettings.
//
// Regla clave de importaciones:
//   Un pedido trae VARIOS productos. Cada producto se pesa individualmente,
//   pero el ENVÍO se paga una sola vez por el pedido completo.
//   Por eso el envío (e impuestos/gastos) se PRORRATEA POR PESO:
//     envioDelProducto = (pesoProducto / pesoTotalDelPedido) * envioTotal
// ===================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===================================================================
// AUTENTICACIÓN (Auth.js) — login seguro con roles
// ===================================================================

enum Role {
  ADMIN // acceso total al panel
  STAFF // futuro: empleados con permisos limitados
  CUSTOMER // futuro: clientes registrados (favoritos, pedidos)
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String? // bcrypt. Null si entra por otro proveedor.
  role          Role      @default(CUSTOMER)
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Modelos que exige el adaptador de Auth.js.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ===================================================================
// CATÁLOGO
// ===================================================================

enum ProductStatus {
  DRAFT // borrador, no visible en la web
  ACTIVE // publicado
  ARCHIVED // fuera del catálogo pero se conserva el historial
}

enum Section {
  STOCK // disponible ya
  ENCARGUE // a pedido
}

enum ProductCondition {
  NEW
  PREOWNED
}

model Brand {
  id      String  @id @default(cuid())
  name    String  @unique
  slug    String  @unique
  logoUrl String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Categorías con jerarquía: una categoría padre ("Ropa", "Calzado",
// "Accesorios") agrupa a sus hijas ("Buzos", "Remeras", ...).
model Category {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  position Int     @default(0) // orden manual en el menú
  parentId String?

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id    String  @id @default(cuid())
  name  String  @unique // Kakobuy, Taobao, Weidian, Yupoo...
  url   String?
  notes String?

  products     Product[]
  importOrders ImportOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  sku         String? @unique

  brandId    String
  categoryId String
  brand      Brand    @relation(fields: [brandId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])

  status    ProductStatus    @default(DRAFT)
  section   Section          @default(ENCARGUE)
  condition ProductCondition @default(NEW)
  featured  Boolean          @default(false) // badge "Destacado"
  soldOut   Boolean          @default(false) // badge "Agotado" (independiente del stock)

  // --- Precio de venta (en pesos uruguayos) ---
  // Si es null o 0 -> la web muestra "Consultar por Instagram".
  salePriceUyu Decimal? @db.Decimal(12, 2)

  // --- Costo y peso (para calcular la ganancia) ---
  // Costo de compra de referencia. El costo REAL sale de ImportItem.
  purchaseCostUsd Decimal? @db.Decimal(12, 2)
  weightGrams     Int? // se pesa individualmente

  // --- Proveedor ---
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supplierUrl String? // link directo (Kakobuy / Taobao / Weidian / Yupoo)

  // --- Stock ---
  stock             Int @default(0)
  lowStockThreshold Int @default(2) // para el aviso de "poco stock"

  // Talles y colores simples (lo que muestra la web hoy).
  sizes  String[]
  colors String[]

  images      ProductImage[]
  variants    ProductVariant[] // stock por talle/color (a futuro)
  importItems ImportItem[] // en qué pedidos vino este producto

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, section])
  @@index([brandId])
  @@index([categoryId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String // Cloudflare R2
  alt       String?
  position  Int     @default(0) // orden de la galería
  isPrimary Boolean @default(false) // imagen principal

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// Preparado para control de stock avanzado (stock por talle/color).
// Todavía no se usa en el panel; el stock simple vive en Product.stock.
model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  size      String?
  color     String?
  sku       String? @unique
  stock     Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size, color])
}

// ===================================================================
// IMPORTACIONES (pedidos al proveedor)
// ===================================================================

enum ImportStatus {
  DRAFT // armando el pedido
  ORDERED // pagado / pedido al proveedor
  SHIPPED // en camino
  RECEIVED // recibido
  CANCELLED
}

model ImportOrder {
  id        String       @id @default(cuid())
  code      String       @unique // ej: "IMP-001"
  status    ImportStatus @default(DRAFT)
  orderDate DateTime     @default(now())

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  // --- Costos del PEDIDO COMPLETO (en USD) ---
  // El envío se paga una sola vez por todo el pedido y luego se
  // prorratea entre los productos SEGÚN SU PESO.
  shippingCostUsd Decimal @default(0) @db.Decimal(12, 2)
  taxesUsd        Decimal @default(0) @db.Decimal(12, 2)
  otherCostsUsd   Decimal @default(0) @db.Decimal(12, 2)

  // Tipo de cambio USD->UYU usado en ESTE pedido (histórico, editable).
  exchangeRate Decimal @db.Decimal(12, 4)

  notes String?
  items ImportItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Un producto dentro de un pedido. Acá vive el costo REAL.
//
// El item puede apuntar a un producto del catálogo (productId) O ser un
// artículo suelto que no se publica en la web (productId null + name).
// Igual pesa y ocupa envío, así que tiene que entrar en el prorrateo.
model ImportItem {
  id            String  @id @default(cuid())
  importOrderId String
  productId     String? // null = producto fuera del catálogo

  importOrder ImportOrder @relation(fields: [importOrderId], references: [id], onDelete: Cascade)
  product     Product?    @relation(fields: [productId], references: [id], onDelete: Restrict)

  /// Nombre a mano, sólo cuando el item no está en el catálogo.
  name String?

  quantity        Int     @default(1)
  unitCostUsd     Decimal @db.Decimal(12, 2) // costo de compra unitario
  unitWeightGrams Int // peso individual de esta prenda

  // --- Prorrateo (lo calcula el sistema, se puede editar a mano) ---
  // allocatedShippingUsd = (pesoDeLaLinea / pesoTotalDelPedido) * shippingCostUsd
  allocatedShippingUsd Decimal? @db.Decimal(12, 2)
  allocatedTaxesUsd    Decimal? @db.Decimal(12, 2)
  allocatedOtherUsd    Decimal? @db.Decimal(12, 2)

  // Costo real unitario = unitCostUsd + (prorrateos / quantity)
  realCostUsd Decimal? @db.Decimal(12, 2)

  // Si el usuario quiere pisar el cálculo automático.
  overrideRealCostUsd Decimal? @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([importOrderId, productId])
  @@index([productId])
}

// ===================================================================
// CONFIGURACIÓN DE LA TIENDA (editable desde el panel, sin tocar código)
// ===================================================================

model StoreSettings {
  id String @id @default("default") // fila única

  storeName String  @default("LeanWear")
  logoUrl   String?
  tagline   String?

  // Contacto / redes
  instagram    String?
  contactEmail String?
  whatsapp     String?

  // Moneda y conversión
  currencySymbol     String  @default("$")
  exchangeRateUsdUyu Decimal @default(40) @db.Decimal(12, 4) // editable
  defaultMarginPct   Decimal @default(50) @db.Decimal(5, 2) // margen sugerido

  // Textos de la web
  encargueLeadTimeDays String? @default("25-30")

  updatedAt DateTime @updatedAt
}

